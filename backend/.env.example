ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SECRET_KEY=replace-with-a-long-random-secret
MONGO_URI=mongodb+srv://user:password%40escaped@cluster.example.mongodb.net/?appName=Cluster0
GROQ_API_KEY=

# Required for production Clerk JWT verification.
# In development, the backend accepts Clerk tokens without signature verification if this is omitted.
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain
